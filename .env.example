## Copy to `.env` and fill in values (do not commit `.env`)

# Groq API
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Data
RESTAURANTS_DB_PATH=data/restaurants.sqlite

# Comma-separated frontend origins allowed to call backend API.
# Example: https://your-app.vercel.app,https://your-app.streamlit.app
CORS_ALLOW_ORIGINS=
